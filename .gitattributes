# These files run/are-read inside Linux containers, so they must keep LF endings
# even when checked out on Windows (Git's autocrlf would otherwise flip them to
# CRLF in the working copy). TASKS.md E1 packaging.
*.sh            text eol=lf
docker-entrypoint.sh text eol=lf
Dockerfile*     text eol=lf
.dockerignore   text eol=lf
docker-compose*.yml text eol=lf
*.conf          text eol=lf
.env.*          text eol=lf
