# my-buddy — environment variable NAMES (no values; §14: no secrets in the repo).
# Copy to .env and fill in locally. .env is gitignored; this template is tracked.

# Postgres connection string (SQLAlchemy/psycopg URL).
DATABASE_URL=

# Anthropic SDK key — server-side only, never reaches the client (§7).
ANTHROPIC_API_KEY=

# Claude model for generation + research (§7). Defaults to claude-opus-4-8.
ANTHROPIC_MODEL=

# Storage adapter selection (§3 / D3): "local" (volume) now, "r2" later.
STORAGE_BACKEND=

# Filesystem path for the local-volume storage adapter.
STORAGE_LOCAL_PATH=

# Public base URL of the app (absolute links).
APP_BASE_URL=

# Auth mode (§2 / D2): "cloudflare_access" (edge auth) or app-level.
AUTH_MODE=

# Session secret — only used if AUTH_MODE is app-level. Keep out of the repo.
SESSION_SECRET=
