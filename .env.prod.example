# my-buddy — PRODUCTION compose environment (docker-compose.prod.yml).
#
# Two ways to use it:
#   • Local prod-like run: copy to `.env` beside the compose file and fill in,
#     then `docker compose -f docker-compose.prod.yml up`.
#   • Coolify: enter these as Environment Variables in the app's settings
#     (Ryan types the secret VALUES himself — see SERVER-SETUP.md).
#
# §14: never commit real values (.env is gitignored; this template is tracked).
# GOTCHA: an empty `VAR=` line is worse than omitting it — delete any line you
# aren't setting rather than leaving it blank.

# --- Postgres (the app's DATABASE_URL is built from these) ---
POSTGRES_USER=my_buddy
POSTGRES_PASSWORD=          # REQUIRED — set a strong random value
POSTGRES_DB=my_buddy

# --- Claude (server-side only; never reaches the client, §7) ---
ANTHROPIC_API_KEY=          # REQUIRED — your Anthropic API key
ANTHROPIC_MODEL=claude-opus-4-8   # optional; this is the default

# --- App ---
APP_BASE_URL=https://mybuddy.example.com   # your real public URL (prod)
WEB_PORT=8080               # host port the nginx frontend binds; Coolify maps
                            # the public domain to this container's port 80
